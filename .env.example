# ============================================
# SANACION CONSCIENTE - Environment Variables
# ============================================

# --- Servidor ---
PORT=3005
NODE_ENV=development

# --- Base de datos PostgreSQL (Local) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sanacion_consciente
DB_USER=postgres
DB_PASS=password

# --- Base de datos PostgreSQL (Produccion - Supabase) ---
# DB_HOST=db.TU_PROJECT_ID.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASS=TU_DB_PASSWORD

# --- Admin Credentials ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$TU_HASH_BCRYPT_AQUI

# --- Session Secret ---
SESSION_SECRET=cambia_esto_por_un_string_largo_y_aleatorio

# --- Email (Nodemailer) ---
# Usar Ethereal para desarrollo: https://ethereal.email/create
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=admin@tudominio.cl
FROM_EMAIL=noreply@tudominio.cl
FROM_NAME=Sanación Consciente ASA
SEND_REAL_EMAILS=false

# --- Google Calendar ---
GOOGLE_CLIENT_ID=TU_CLIENT_ID_AQUI
GOOGLE_CLIENT_SECRET=TU_CLIENT_SECRET_AQUI
GOOGLE_REDIRECT_URI=http://localhost:3005/backend/api/google-calendar/callback
GOOGLE_CALENDAR_ID=primary

# --- WhatsApp ---
WHATSAPP_NUMBER=569XXXXXXXX
