# ============================================
# SANACION CONSCIENTE - Environment Variables
# ============================================

# --- Servidor ---
PORT=3005
NODE_ENV=development

# --- Base de datos PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sanacion_consciente
DB_USER=postgres
DB_PASS=password

# --- Session Secret ---
SESSION_SECRET=cambia_esto_por_un_string_largo_y_aleatorio

# --- Email (Nodemailer) ---
# Usar Ethereal para desarrollo: https://ethereal.email/create
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=masajesanacionasa@gmail.com
FROM_EMAIL=masajesanacionasa@gmail.com
FROM_NAME=Sanación Consciente ASA
SEND_REAL_EMAILS=false

# --- Google Calendar ---
GOOGLE_CLIENT_ID=TU_CLIENT_ID_AQUI
GOOGLE_CLIENT_SECRET=TU_CLIENT_SECRET_AQUI
GOOGLE_REDIRECT_URI=http://localhost:3005/backend/api/google-calendar/callback
GOOGLE_CALENDAR_ID=primary

# --- WhatsApp ---
WHATSAPP_NUMBER=56912345678
